# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase 프로젝트 설정 > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버 전용 — 클라이언트에 절대 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
# 서버 전용
OPENAI_API_KEY=sk-...

# ─── Sentry ───────────────────────────────────────────────────────────────────
# https://sentry.io → 프로젝트 → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# BotFather에서 /newbot으로 발급
# 서버 전용
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHI...

# 허용 Telegram chat_id (Owner, Spouse) — 콤마로 구분
# chat_id 확인: @userinfobot 에서 /start 후 확인
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# 운영 에러 알림 수신 chat_id (보통 Owner chat_id와 동일)
TELEGRAM_OPS_CHAT_ID=123456789

# ─── Google Sheets 백업 ───────────────────────────────────────────────────────
# Vercel Cron 인증용 임의 시크릿 (openssl rand -hex 32)
CRON_SECRET=your-random-secret-here

# 구글 서비스 계정 JSON 전체를 문자열화
# cat service-account.json | jq -c . 로 생성
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# 백업 구글시트 ID (URL에서 /d/SPREADSHEET_ID/ 부분)
BACKUP_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ─── 환율 API (OD-002) ────────────────────────────────────────────────────────
# https://www.exchangerate-api.com/ 에서 무료 발급 (월 1,500회)
EXCHANGE_RATE_API_KEY=your-api-key-here
